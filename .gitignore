*.ilk
*.pdb
*.cache
*.log
*.obj
*.o
*.dll
*.exe

# IIS Express
IISExpress/

# User-specific files
*.rsuser
*.user

# OS generated files
Thumbs.db
.DS_Store

# JetBrains Rider
.idea/
*.sln.iml

# Other
*.vsix

# Keep project content files (like recipes.json) under source control unless intentionally excluded.
