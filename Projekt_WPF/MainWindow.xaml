<Window x:Class="Projekt_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hormone Harmony"
        Height="820"
        Width="1200"
        Background="#F5EAEA">

    <Window.Resources>
        <Style x:Key="FilterChipStyle" TargetType="ToggleButton">
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="Background" Value="#EFE6E6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd" 
                            Background="{TemplateBinding Background}" 
                            CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" 
                                          VerticalAlignment="Center" 
                                          Margin="6,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E3D7D7"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF4F6F"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RecipeCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.15"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#F1E5E5">
            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="❤" FontSize="22" Margin="0,0,10,0"/>
                    <TextBlock Text="Hormone Harmony" FontSize="22" FontWeight="Bold" Foreground="#5A1E1E"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Column="1">
                    <Button Content="Browse Recipes"
                            Click="BrowseRecipes_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Margin="0,0,20,0"
                            Cursor="Hand"/>
                    <Button Content="+ Add Recipe" Click="AddRecipe_Click" Padding="14,6" Background="#E7DADA" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="40">

                <Border Background="#F8EFEF" CornerRadius="20" Padding="40" Margin="0,0,0,30">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Nourish Your Body" FontSize="44" FontWeight="Bold" Foreground="#4A0F0F" TextAlignment="Center"/>
                        <TextBlock Text="Discover recipes crafted to support hormonal balance and help you feel best every day." FontSize="16" Margin="0,10,0,0" Foreground="#666" Width="620" TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Grid Margin="0,0,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="420"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="White" CornerRadius="20" Padding="12" BorderBrush="#E0D0D0" BorderThickness="1">
                        <DockPanel>
                            <TextBlock Text="🔍" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBox Name="SearchTextBox" 
                                 BorderThickness="0" 
                                 Foreground="Gray" 
                                 VerticalAlignment="Center"
                                 Text="Search by ingredient or dish..." 
                                 Background="Transparent" 
                                 GotFocus="TextBox_GotFocus"
                                 LostFocus="TextBox_LostFocus"
                                 TextChanged="SearchTextBox_TextChanged"/>
                        </DockPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" Grid.Column="1" Margin="20,0,0,0">
                        <ToggleButton x:Name="BtnAll" Content="All" 
                  Style="{StaticResource FilterChipStyle}" 
                  IsChecked="True" 
                  Click="Filter_Click"/>

                        <ToggleButton x:Name="BtnProteins" Content="Proteins" 
                  Style="{StaticResource FilterChipStyle}" 
                  Click="Filter_Click"/>

                        <ToggleButton x:Name="BtnFats" Content="Healthy Fats" 
                  Style="{StaticResource FilterChipStyle}" 
                  Click="Filter_Click"/>

                        <ToggleButton x:Name="BtnGreens" Content="Greens" 
                  Style="{StaticResource FilterChipStyle}" 
                  Click="Filter_Click"/>

                        <ToggleButton x:Name="BtnFruits" Content="Fruits" 
                  Style="{StaticResource FilterChipStyle}" 
                  Click="Filter_Click" Cursor="Hand"/>
                    </StackPanel>
                </Grid>

                <ListBox ItemsSource="{Binding Recipes}" 
                     Background="Transparent" 
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.CanContentScroll="False" 
                     MouseDoubleClick="RecipesListBox_MouseDoubleClick">

                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel HorizontalAlignment="Center" ItemWidth="330"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource RecipeCard}" Width="305">
                                <StackPanel>
                                    <Image Source="{Binding ImagePath}" Height="220" Stretch="Fill" Cursor="Hand"/>
                                    <StackPanel Margin="15">
                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="16"/>
                                        <TextBlock Text="{Binding ShortDescription}" TextWrapping="Wrap" Margin="0,6,0,0" Foreground="#666"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <TextBlock Text="{Binding Kcal, StringFormat={}{0} kcal}" Foreground="#FF4F6F" FontWeight="Bold"/>
                                            <TextBlock Text=" • " Foreground="#AAA"/>
                                            <TextBlock Text="{Binding TimeMin, StringFormat={}{0} min}" Foreground="#AAA"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>