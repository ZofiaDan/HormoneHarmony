<Window x:Class="Projekt_WPF.AddRecipeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Recipe"
        Height="700"
        Width="900"
        Background="#F6EDEE">
    <Window.Resources>

        <Style x:Key="ChipButton" TargetType="Button">
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="Background" Value="#EFE6E6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="20">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="6,0"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E3D7D7"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#D7CACA"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- Aktywny filtr -->
        <Style x:Key="ChipActive" BasedOn="{StaticResource ChipButton}" TargetType="Button">
            <Setter Property="Background" Value="#FF4F6F"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>


        <!-- Karta przepisu -->
        <Style x:Key="RecipeCard" TargetType="Border">
            <Setter Property="Width" Value="330"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12"
                                      ShadowDepth="3"
                                      Opacity="0.15"/>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="40">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TITLE -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0 0 0 30">
                <TextBlock
                    Text="Add a New Recipe"
                    FontSize="34"
                    FontWeight="Bold"
                    Foreground="#5A0F1D"
                    HorizontalAlignment="Center"/>

                <TextBlock
                    Text="Share your hormone-balancing creations."
                    FontSize="14"
                    Foreground="#7A7A7A"
                    HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- MAIN CARD -->
            <Border Grid.Row="1"
                    Background="White"
                    CornerRadius="20"
                    Padding="30">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="15"
                                      ShadowDepth="3"
                                      Opacity="0.25"/>
                </Border.Effect>

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT SIDE -->
                    <StackPanel Grid.Column="0" Margin="0 0 20 0">

                        <TextBlock
                            Text="Dish Photo"
                            FontWeight="Bold"
                            FontSize="18"
                            Foreground="#7C1A2B"
                            Margin="0 0 0 10"/>

                        <Border Height="180"
                                BorderBrush="#F2B6BE"
                                BorderThickness="2"
                                CornerRadius="12"
                                Background="#FFF7F8"
                                Margin="0 0 0 25">

                            <Grid>
                                <TextBlock
                                    Text="Click to upload a photo"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="#E26A78"/>
                            </Grid>

                        </Border>

                        <TextBlock
                            Text="Recipe Title"
                            FontWeight="SemiBold"/>

                        <TextBox Height="35"
                                 Margin="0 8 0 20"
                                 Padding="8"
                                 Background="#FFF7F8"
                                 BorderBrush="#F2B6BE"/>

                        <TextBlock
                            Text="Description"
                            FontWeight="SemiBold"/>

                        <TextBox Height="80"
                                 Margin="0 8 0 0"
                                 Padding="8"
                                 Background="#FFF7F8"
                                 BorderBrush="#F2B6BE"
                                 AcceptsReturn="True"/>

                    </StackPanel>

                    <!-- RIGHT SIDE -->
                    <StackPanel Grid.Column="1" Grid.Row="5">

                        <TextBlock
                            Text="Key Ingredients"
                            FontWeight="Bold"
                            FontSize="18"
                            Foreground="#7C1A2B"
                            Margin="0 0 0 10"/>

                        <ScrollViewer MaxHeight="200" Width="380" VerticalScrollBarVisibility="Auto">
                            <WrapPanel Orientation="Horizontal" Margin="10,0,0,0">
                                <Button Content="Salmon" Style="{StaticResource ChipActive}" Padding="20, 10" Margin="5"/>
                                <Button Content="Avocado" Style="{StaticResource ChipButton}" Padding="20, 10" Margin="5"/>
                                <Button Content="Olive Oil" Style="{StaticResource ChipButton}" Padding="20, 10" Margin="5"/>
                                <Button Content="Egg" Style="{StaticResource ChipButton}" Padding="20, 10" Margin="5"/>
                                <Button Content="Walnuts" Style="{StaticResource ChipButton}" Padding="20, 10" Margin="5"/>
                                <Button Content="Berries" Style="{StaticResource ChipButton}" Padding="20, 10" Margin="5"/>
                                <Button Content="Seeds" Style="{StaticResource ChipButton}" Padding="20, 10" Margin="5"/>
                            </WrapPanel>
                        </ScrollViewer>

                        <TextBlock
                            Text="Full Ingredients List"
                            FontWeight="SemiBold"
                            Margin="0 15 0 8"/>

                        <TextBox Height="100"
                             Padding="8"
                             Background="#FFF7F8"
                             BorderBrush="#F2B6BE"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"/>
                        <Button
                            Content="Save Recipe"
                            Height="45"
                            Margin="0 20 0 0" 
                            Background="#E85D75"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"/>

                    </StackPanel>

                </Grid>

            </Border>

        </Grid>

    </ScrollViewer>

</Window>