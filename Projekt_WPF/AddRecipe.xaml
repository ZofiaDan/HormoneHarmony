<Window x:Class="Projekt_WPF.AddRecipeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Recipe" Height="820" Width="900" Background="#F6EDEE">
    <Window.Resources>
        <Style x:Key="ChipButton" TargetType="Button">
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="Background" Value="#EFE6E6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="6,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0 0 0 30">
                <TextBlock Text="Add a New Recipe" FontSize="34" FontWeight="Bold" Foreground="#5A0F1D" HorizontalAlignment="Center"/>
                <TextBlock Text="Drag a photo and fill in the details below." FontSize="14" Foreground="#7A7A7A" HorizontalAlignment="Center"/>
            </StackPanel>

            <Border Grid.Row="1" Background="White" CornerRadius="20" Padding="30">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.25"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0 0 20 0">
                        <TextBlock Text="Dish Photo" FontWeight="Bold" FontSize="18" Foreground="#7C1A2B" Margin="0 0 0 10"/>
                        <Border x:Name="ImageDropZone" Height="180" BorderBrush="#F2B6BE" BorderThickness="2" CornerRadius="12" Background="#FFF7F8" Margin="0 0 0 25" AllowDrop="True" Drop="ImageDropZone_Drop">
                            <Grid>
                                <Image x:Name="ImgPreview" Stretch="UniformToFill" Margin="2"/>
                                <TextBlock x:Name="DropText" Text="Drag &amp; Drop photo here" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#E26A78"/>
                            </Grid>
                        </Border>

                        <TextBlock Text="Recipe Title" FontWeight="SemiBold"/>
                        <TextBox x:Name="TitleInput" Height="35" Margin="0 8 0 15" Padding="8" Background="#FFF7F8" BorderBrush="#F2B6BE"/>

                        <StackPanel Orientation="Horizontal" Margin="0 0 0 15">
                            <StackPanel Width="150" Margin="0 0 20 0">
                                <TextBlock Text="Calories (kcal)" FontWeight="SemiBold"/>
                                <TextBox x:Name="KcalInput" Height="35" Margin="0 8 0 0" Padding="8" Background="#FFF7F8" BorderBrush="#F2B6BE"/>
                            </StackPanel>
                            <StackPanel Width="150">
                                <TextBlock Text="Time (min)" FontWeight="SemiBold"/>
                                <TextBox x:Name="TimeInput" Height="35" Margin="0 8 0 0" Padding="8" Background="#FFF7F8" BorderBrush="#F2B6BE"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="Short Description" FontWeight="SemiBold"/>
                        <TextBox x:Name="ShortDescInput" Height="35" Margin="0 8 0 15" Padding="8" Background="#FFF7F8" BorderBrush="#F2B6BE"/>

                        <TextBlock Text="Key Ingredients / Hormone Heroes (separate with ; )" FontWeight="SemiBold"/>
                        <TextBox x:Name="KeyIngredientsInput" Height="35" Margin="0 8 0 15" Padding="8" Background="#FFF7F8" BorderBrush="#F2B6BE"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Full Description / Why it helps" FontWeight="SemiBold"/>
                        <TextBox x:Name="DescriptionInput" Height="80" Margin="0 8 0 15" Padding="8" Background="#FFF7F8" BorderBrush="#F2B6BE" AcceptsReturn="True" TextWrapping="Wrap"/>

                        <TextBlock Text="Ingredients (separate with ; )" FontWeight="SemiBold"/>
                        <TextBox x:Name="IngredientsInput" Height="100" Margin="0 8 0 15" Padding="8" Background="#FFF7F8" BorderBrush="#F2B6BE" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>

                        <TextBlock Text="Steps (separate with | )" FontWeight="SemiBold"/>
                        <TextBox x:Name="StepsInput" Height="100" Margin="0 8 0 15" Padding="8" Background="#FFF7F8" BorderBrush="#F2B6BE" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>

                        <Button x:Name="BtnSave" Content="Save Recipe" Click="BtnSave_Click" Height="45" Margin="0 10 0 0" Background="#E85D75" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>