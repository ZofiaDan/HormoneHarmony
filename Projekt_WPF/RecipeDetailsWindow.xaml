<Window x:Class="Projekt_WPF.RecipeDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recipe Details"
        Height="850"
        Width="1100"
        Background="#F5EAEA">

    <Window.Resources>
        <Style x:Key="CardShadow" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.25"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer>
        <StackPanel Margin="40">

            <TextBlock Text="← Back to recipes"
                       Foreground="#3B4A6B"
                       Margin="0,0,0,20"
                       FontWeight="SemiBold"
                       Cursor="Hand"
                       MouseLeftButtonUp="TextBlock_MouseLeftButtonUp"/>

            <Grid Height="230">
                <Image Source="{Binding ImagePath}" Stretch="UniformToFill" Height="200" Margin="0,0,0,60"/>

                <Border Background="#66000000" Height="200" Margin="0,0,0,60"/>

                <TextBlock Text="{Binding Title}"
                           Foreground="White"
                           FontSize="40"
                           FontWeight="Bold"
                           VerticalAlignment="Top"
                           Margin="20,115,20,0"/>
            </Grid>

            <Border Background="#EFEFEF" CornerRadius="15" Padding="20" Height="60" Width="1001">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding TimeMin, StringFormat='⏱ {0} min'}" Margin="20,0"/>
                    <TextBlock Text="{Binding Kcal, StringFormat='🔥 {0} kcal'}" Margin="20,0"/>
                    <TextBlock Text="{Binding Ingredients.Count, StringFormat='ℹ {0} Ingredients'}" Margin="20,0"/>
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource CardShadow}" Background="#F6EAEA" Margin="0,10,30,10">
                    <StackPanel>
                        <TextBlock Text="Ingredients" FontSize="22" FontWeight="Bold" Foreground="#8B1D2C" Margin="0,0,0,15"/>

                        <ItemsControl ItemsSource="{Binding Ingredients}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StringFormat='• {0}'}" Margin="0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardShadow}" Grid.Column="1" Margin="0,10,0,10">
                    <StackPanel>
                        <TextBlock Text="Instructions" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

                        <ItemsControl ItemsSource="{Binding Steps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,0,0,15">
                                        <TextBlock Text="✔" Margin="0,0,10,0" Foreground="#FF4F6F"/>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Margin="0,30,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource CardShadow}" Background="#EFEFEF" Margin="0,10,30,10">
                    <StackPanel>
                        <TextBlock Text="Hormone Heroes" FontWeight="Bold" Margin="0,0,0,10"/>
                        <ItemsControl ItemsSource="{Binding KeyIngredients}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F4C9CE" CornerRadius="15" Padding="10,4" Margin="5">
                                        <TextBlock Text="{Binding}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardShadow}" Background="#F6EAEA" Grid.Column="1" Margin="0,10,0,10">
                    <StackPanel>
                        <TextBlock Text="❤ Why it helps" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontStyle="Italic"/>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Window>